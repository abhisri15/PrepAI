# PrepAI Backend — copy this file to .env and fill in your keys

# ── LLM Provider ──────────────────────────────────────────────────────────────
# "auto" picks the first available key; or set explicitly: mock | groq | openai | anthropic | gemini
LLM_PROVIDER=auto
LLM_MODEL=llama-3.3-70b-versatile

# ── API Keys (fill in the ones you have) ─────────────────────────────────────
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GROQ_MODEL=llama-3.3-70b-versatile
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# ── n8n webhook ───────────────────────────────────────────────────────────────
# URL of the "Interview Prep Assistant" webhook in your n8n instance
N8N_PREPAI_WEBHOOK_URL=https://your-n8n-instance/webhook/interview-prep
N8N_TIMEOUT_SECS=10

# ── App ───────────────────────────────────────────────────────────────────────
DEBUG=false
SECRET_KEY=change-me-in-production

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (use * for all — not recommended in prod)
CORS_ORIGINS=http://localhost:5173,https://your-frontend.netlify.app
