# Backend Environment - copy to .env
LLM_PROVIDER=gemini
LLM_MODEL=gemini-1.5-flash
DEBUG=true
SECRET_KEY=dev-secret-key
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# Groq (used for /api/ask when set - fast inference)
# GROQ_API_KEY=
# GROQ_MODEL=llama-3.3-70b-versatile

# n8n webhook for Prep Guide (form submit → email prep guide)
# Use the URL where your "Interview Prep Assistant" workflow webhook is listening
N8N_PREPAI_WEBHOOK_URL=https://prepai.app.n8n.cloud/webhook/interview-prep
# Alternative key (checked if above is not set):
# N8N_FORM_WEBHOOK_URL=https://prepai.app.n8n.cloud/webhook/interview-prep
