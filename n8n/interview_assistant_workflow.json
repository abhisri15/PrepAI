{
  "name": "PrepAI Interview Assistant",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "prepai-webhook",
        "responseMode": "responseNode",
        "options": {}
      },
      "id": "webhook-trigger",
      "name": "Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1,
      "position": [250, 300],
      "webhookId": "prepai-webhook"
    },
    {
      "parameters": {
        "values": {
          "string": [
            {
              "name": "action",
              "value": "={{ $json.body.action || 'ask' }}"
            },
            {
              "name": "question",
              "value": "={{ $json.body.question || $json.body.query || '' }}"
            },
            {
              "name": "candidate_answer",
              "value": "={{ $json.body.candidate_answer || $json.body.answer || '' }}"
            },
            {
              "name": "resume_text",
              "value": "={{ $json.body.resume_text || $json.body.resume || '' }}"
            },
            {
              "name": "jd_text",
              "value": "={{ $json.body.jd_text || $json.body.job_description || $json.body.jd || '' }}"
            }
          ]
        },
        "options": {}
      },
      "id": "set-node",
      "name": "Set Payload",
      "type": "n8n-nodes-base.set",
      "typeVersion": 1,
      "position": [450, 300]
    },
    {
      "parameters": {
        "modelId": {
          "__rl": true,
          "value": "gpt-4o-mini",
          "mode": "list",
          "cachedResultName": "GPT-4O-MINI"
        },
        "messages": {
          "values": [
            {
              "content": "=You are PrepAI Interview Assistant. Return ONLY valid JSON and no markdown.\n\nAction: {{$json.action}}\nQuestion: {{$json.question}}\nCandidate Answer: {{$json.candidate_answer}}\nResume: {{$json.resume_text}}\nJob Description: {{$json.jd_text}}\n\nIf action is ask, return: {\"answer\": string, \"improvements\": string[], \"confidence\": number 0..1, \"sources\": string[]}\nIf action is evaluate, return: {\"score\": number 0..10, \"rationale\": string, \"improvements\": string[], \"confidence\": number 0..1}\nIf action is prepare, return: {\"strengths\": string[], \"weaknesses\": string[], \"key_topics\": string[], \"practice_questions\": string[], \"study_plan\": string[]}"
            }
          ]
        },
        "options": {}
      },
      "id": "http-request",
      "name": "Generate Response",
      "type": "@n8n/n8n-nodes-langchain.openAi",
      "typeVersion": 1.8,
      "position": [650, 300]
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={{ $json }}"
      },
      "id": "webhook-response",
      "name": "Webhook Response",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1,
      "position": [850, 300]
    }
  ],
  "connections": {
    "Webhook": {
      "main": [
        [
          {
            "node": "Set Payload",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Set Payload": {
      "main": [
        [
          {
            "node": "HTTP Request to PrepAI",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "HTTP Request to PrepAI": {
      "main": [
        [
          {
            "node": "Webhook Response",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "meta": {
    "templateCredsSetupCompleted": true
  }
}
