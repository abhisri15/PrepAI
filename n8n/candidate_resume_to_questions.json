{
  "name": "PrepAI Candidate Resume to Questions",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "resume-to-questions",
        "responseMode": "responseNode",
        "options": {}
      },
      "id": "webhook",
      "name": "Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1,
      "position": [250, 300]
    },
    {
      "parameters": {
        "modelId": {
          "__rl": true,
          "value": "gpt-4o-mini",
          "mode": "list",
          "cachedResultName": "GPT-4O-MINI"
        },
        "messages": {
          "values": [
            {
              "content": "=You are PrepAI preparation planner. Return ONLY valid JSON and no markdown.\n\nResume: {{$json.body.resume || $json.body.resume_text || ''}}\nJob Description: {{$json.body.jd || $json.body.jd_text || $json.body.job_description || ''}}\n\nReturn exactly this schema:\n{\"strengths\": string[], \"weaknesses\": string[], \"key_topics\": string[], \"practice_questions\": string[], \"study_plan\": string[]}"
            }
          ]
        },
        "options": {}
      },
      "id": "http",
      "name": "Generate Prep Plan",
      "type": "@n8n/n8n-nodes-langchain.openAi",
      "typeVersion": 1.8,
      "position": [450, 300]
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={{ $json }}"
      },
      "id": "response",
      "name": "Response",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1,
      "position": [650, 300]
    }
  ],
  "connections": {
    "Webhook": {
      "main": [[{ "node": "PrepAI Prepare", "type": "main", "index": 0 }]]
    },
    "PrepAI Prepare": {
      "main": [[{ "node": "Response", "type": "main", "index": 0 }]]
    }
  }
}
