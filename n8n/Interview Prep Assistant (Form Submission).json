          "value": "gpt-4o-mini",
          "mode": "list",
          "cachedResultName": "GPT-4O-MINI"
        },
        "messages": {
          "values": [
            {
              "role": "system",
              "content": "You are a technical recruiter evaluating candidate fit for a job role. Analyze the resume against the job description carefully. Respond with ONLY a raw JSON object — no markdown, no code blocks, no extra text."
            },
            {
              "content": "=Evaluate whether this candidate is a good fit for the role.\n\nRole: {{ $json.role }}\n\nJob Description:\n{{ $json.jd_text }}\n\nResume:\n{{ $json.resume_text }}\n\nAdditional Notes:\n{{ $json.additional_notes }}\n\nBe generous: if the candidate has relevant experience in the field or adjacent skills, mark them as qualified. Return exactly this JSON:\n{\"qualified\": true, \"reason\": \"One sentence explaining the fit\"}\nor\n{\"qualified\": false, \"reason\": \"One sentence explaining the mismatch\"}"
            }
          ]
        },
        "options": {}
      },
      "type": "@n8n/n8n-nodes-langchain.openAi",
      "typeVersion": 1.8,
      "position": [480, 200],
      "id": "openai-qualify-001",
      "name": "Qualify Candidate",
      "credentials": {
        "openAiApi": {
          "id": "jSTot0m8NRHUoumT",
          "name": "n8n free OpenAI API credits"
        }
      }
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict",
            "version": 2
          },
          "conditions": [
            {
              "id": "cond-qualified",
              "leftValue": "={{ $json.message.content }}",
              "rightValue": "\"qualified\": true",
              "operator": {
                "type": "string",
                "operation": "contains"
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "type": "n8n-nodes-base.if",
