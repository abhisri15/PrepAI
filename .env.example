# PrepAI Environment Variables
# Copy to .env and customize

# AI Provider: mock | openai | anthropic | gemini
# mock = offline demo, deterministic responses
LLM_PROVIDER=mock
LLM_MODEL=gpt-4

# API Keys (only needed when not using mock)
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GOOGLE_API_KEY=

# Optional
DEBUG=true
SECRET_KEY=change-me-in-production
